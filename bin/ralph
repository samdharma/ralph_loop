#!/usr/bin/env bash
# Ralph v3 — CLI Entry Point
#
# Dispatches to Python modules for all subcommands.
# No beads. No dolt. GitHub-native.

set -euo pipefail

# Detect RALPH_HOME
if [[ -n "${RALPH_HOME:-}" ]]; then
    RALPH_HOME="${RALPH_HOME}"
elif [[ -L "$0" ]]; then
    # Follow symlink to find the real location
    RALPH_HOME="$(cd "$(dirname "$(readlink "$0")")/.." && pwd)"
else
    RALPH_HOME="$(cd "$(dirname "$0")/.." && pwd)"
fi

CORE_DIR="${RALPH_HOME}/core"
PYTHON_CMD="${RALPH_PYTHON_CMD:-python3}"
PROJECT_DIR="${RALPH_PROJECT_DIR:-$(pwd)}"

export RALPH_PROJECT_DIR="${PROJECT_DIR}"
export RALPH_CORE_DIR="${CORE_DIR}"

# ─────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────

cmd_version() {
    echo "ralph v3.1.2"
}

cmd_help() {
    echo "Ralph v3 — Automated Build System"
    echo ""
    echo "Usage: ralph <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init [dir]         Scaffold a Ralph project (default: current directory)"
    echo "  setup              Check prerequisites and prepare local dirs"
    echo "  daemon [opts]      Start the build loop (foreground — use & for background)"
    echo "  status             Show project health dashboard"
    echo "  validate [opts]    Run the validation gate"
    echo "  report             Generate daily/weekly summary"
    echo "  generate-test-map  Auto-generate TEST_MAP.yaml from project structure"
    echo "  migrate [opts]     Migrate v3 state files to v3.1 layout (--dry-run supported)"
    echo "  trajectory <N>     Print the timeline of trajectory events for issue #N"
    echo "  doctor [N]         Diagnose Ralph's runtime health (5 categories)"
    echo "  version            Show version"
    echo "  help               Show this help"
    echo ""
    echo "Quick start:"
    echo "  ralph init                     # Set up Ralph in current directory"
    echo "  ralph init my-project          # Create a new project"
    echo "  ralph init --create-labels     # Also create GitHub labels"
    echo "  ralph init . --yes             # Non-interactive with defaults"
    echo "  ralph init . --yes --github-project 5  # Enable Kanban board sync"
    echo ""
    echo "Options:"
    echo "  init --yes, -y       Non-interactive mode (use defaults)"
    echo "  init --create-labels Create Ralph labels on GitHub repo"
    echo "  init --github-project N  Enable GitHub Project board sync for project N"
    echo "  init --agent=<pi|kimi>  AI agent to use"
    echo "  init --tier=<tier>   Default test tier"
    echo "  validate --tier=<smoke|targeted|integration|full>"
    echo "  daemon --agent=<pi|kimi>  AI agent to use (overrides RALPH_AGENT and config)"
echo "  daemon --auto-close       Close issues on success (skip human review)"
    echo "  daemon --issue=N          Process only issue #N and exit"
    echo "  daemon --pi-flag=FLAG     Extra pi flag (repeatable, validated against pi --help)"
    echo ""
    echo "Environment:"
    echo "  RALPH_PROJECT_DIR      Project root (default: pwd)"
    echo "  RALPH_HOME             Ralph install directory"
    echo "  RALPH_PYTHON_CMD       Python executable (default: python3)"
    echo "  RALPH_AGENT            AI agent binary (pi or kimi)"
    echo "  RALPH_GITHUB_PROJECT   Override ticket.project for board sync"
    echo "  RALPH_PROJECT_SYNC     Set to 0/1 to disable/enable board sync"
}

cmd_init() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/init.py" "$@"
}

cmd_setup() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/setup.py" "$@"
}

cmd_daemon() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/engine.py" "$@"
}

cmd_status() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/status.py" "$@"
}

cmd_validate() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/validate.py" "$@"
}

cmd_report() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/report.py" "$@"
}

cmd_generate_test_map() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/generate_test_map.py" "$@"
}

cmd_migrate() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/migrate.py" "$@"
}

cmd_trajectory() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/trajectory.py" "$@"
}

cmd_doctor() {
    exec "${PYTHON_CMD}" "${CORE_DIR}/doctor.py" "$@"
}

# ─────────────────────────────────────────────────────────
# Dispatch
# ─────────────────────────────────────────────────────────

case "${1:-help}" in
    version|--version|-v)      cmd_version ;;
    help|--help|-h)            cmd_help ;;
    init)                      shift; cmd_init "$@" ;;
    setup)                     shift; cmd_setup "$@" ;;
    daemon)                    shift; cmd_daemon "$@" ;;
    status)                    shift; cmd_status "$@" ;;
    validate)                  shift; cmd_validate "$@" ;;
    report)                    shift; cmd_report "$@" ;;
    generate-test-map)         shift; cmd_generate_test_map "$@" ;;
    migrate)                   shift; cmd_migrate "$@" ;;
    trajectory)                shift; cmd_trajectory "$@" ;;
    doctor)                    shift; cmd_doctor "$@" ;;
    *)
        echo "ralph: unknown command '${1}'"
        echo "Run 'ralph help' for usage."
        exit 1
        ;;
esac
