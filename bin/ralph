#!/usr/bin/env bash
# ralph — Ralph Wiggum Loop Build System CLI v1.3.0
#
# Global tool. All build scripts live in ~/.ralph/core/.
# Projects carry only .ralph/config.toml and project-specific config files.
#
# Usage:
#   ralph init               Scaffold a new project
#   ralph setup              Post-clone setup (beads init + dolt pull)
#   ralph status             Show project health dashboard
#   ralph loop [opts]        Run build loop (foreground)
#   ralph daemon [opts]      Run build loop (background daemon)
#   ralph build [opts]       Run full 4-stage pipeline for a ticket
#   ralph validate [opts]    Run validation gate (tests + lint)
#   ralph health [opts]      Check loop and project health
#   ralph report [opts]      Generate daily/weekly report
#   ralph metrics [opts]     View loop metrics analytics
#   ralph sync               Fetch origin, check for hotfix/remote updates
#   ralph migrate            Convert legacy project to new config format
#   ralph version            Show version
#   ralph help               Show this help

set -euo pipefail

RALPH_HOME="${RALPH_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
export RALPH_HOME
CORE_DIR="${RALPH_HOME}/core"

# ──────────────────────────────────────────────────────────────
# Walk up from cwd to find a Ralph project root.
# A Ralph project has .ralph/config.toml (or legacy scripts/ralph/).
# ──────────────────────────────────────────────────────────────
find_project_dir() {
    local dir="${PWD}"
    while [[ "${dir}" != "/" ]]; do
        if [[ -f "${dir}/.ralph/config.toml" ]]; then
            echo "${dir}"
            return 0
        fi
        # Legacy fallback
        if [[ -f "${dir}/scripts/ralph/ralph_loop.sh" ]]; then
            echo "${dir}"
            return 0
        fi
        dir="$(dirname "${dir}")"
    done
    return 1
}

require_project() {
    PROJECT_DIR="$(find_project_dir)"
    if [[ -z "${PROJECT_DIR}" ]]; then
        echo "ralph: not in a Ralph project."
        echo "  No .ralph/config.toml found in $(pwd) or any parent."
        echo "  Run 'ralph init' first, or 'ralph setup' after cloning."
        exit 1
    fi
    export RALPH_PROJECT_DIR="${PROJECT_DIR}"
}

run_core() {
    local script="$1"
    shift
    if [[ ! -f "${CORE_DIR}/${script}" ]]; then
        echo "ralph: error — core script not found: ${CORE_DIR}/${script}"
        echo "  Is RALPH_HOME set correctly? (current: ${RALPH_HOME})"
        exit 1
    fi
    exec bash "${CORE_DIR}/${script}" "$@"
}

# ──────────────────────────────────────────────────────────────
# Main dispatch
# ──────────────────────────────────────────────────────────────

case "${1:-}" in
    init)
        shift
        exec python3 "${RALPH_HOME}/init.py" "$@"
        ;;

    setup)
        shift
        exec python3 "${RALPH_HOME}/init.py" --setup "$@"
        ;;

    status)
        exec python3 "${RALPH_HOME}/init.py" --status
        ;;

    loop)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        run_core "ralph_loop.sh" "$@"
        ;;

    daemon)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        export RALPH_PROJECT_DIR="${PROJECT_DIR}"
        exec bash "${CORE_DIR}/run_ralph_loop.sh" "$@"
        ;;

    design)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        run_core "ralph_loop.sh" --session=design "$@"
        ;;

    test)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        run_core "ralph_loop.sh" --session=test "$@"
        ;;

    implement)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        run_core "ralph_loop.sh" --session=implement "$@"
        ;;

    verify)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        run_core "ralph_loop.sh" --session=verify "$@"
        ;;

    build)
        shift
        require_project
        if [[ ! -d "${PROJECT_DIR}/.beads" ]]; then
            echo "ralph: beads not initialized. Run 'ralph setup' first."
            exit 1
        fi
        run_core "ralph_build.sh" "$@"
        ;;

    validate)
        shift
        require_project
        run_core "ralph_validate.sh" "$@"
        ;;

    health)
        shift
        require_project
        run_core "ralph_health.sh" "$@"
        ;;

    sync)
        shift
        require_project
        export RALPH_PROJECT_DIR="${PROJECT_DIR}"
        cd "${PROJECT_DIR}"
        # Run the sync gate manually and report status
        echo "[ralph] Manual remote sync check..."
        if ! git remote &>/dev/null || [[ -z "$(git remote)" ]]; then
            echo "[ralph] No git remote configured."
            exit 0
        fi
        UPSTREAM=$(git rev-parse --abbrev-ref '@{u}' 2>/dev/null || true)
        if [[ -z "${UPSTREAM}" ]]; then
            echo "[ralph] No upstream tracking branch."
            exit 0
        fi
        git fetch origin --quiet 2>/dev/null || {
            echo "[ralph] ERROR: git fetch failed. Check network."
            exit 1
        }
        LOCAL=$(git rev-parse HEAD)
        REMOTE=$(git rev-parse '@{u}')
        BASE=$(git merge-base HEAD '@{u}' 2>/dev/null || true)
        echo "[ralph] Local : ${LOCAL:0:7}"
        echo "[ralph] Remote: ${REMOTE:0:7}"
        if [[ "${LOCAL}" == "${REMOTE}" ]]; then
            echo "[ralph] Status: up-to-date."
        elif [[ "${LOCAL}" == "${BASE}" ]]; then
            echo "[ralph] Status: behind remote (hotfixes available)."
            echo "[ralph] Run 'git rebase @{u}' to integrate, or let the daemon auto-sync."
        elif [[ "${REMOTE}" == "${BASE}" ]]; then
            echo "[ralph] Status: ahead of remote (unpushed commits)."
        else
            echo "[ralph] Status: DIVERGED — manual intervention required."
            echo "[ralph] Run 'git pull --rebase' and resolve conflicts."
            exit 1
        fi
        ;;

    report)
        shift
        require_project
        run_core "ralph_report.sh" "$@"
        ;;

    metrics)
        shift
        require_project
        PYTHON_CMD="${RALPH_PYTHON_CMD:-}"
        VENV_PATH="${PROJECT_DIR}/.venv"
        if [[ -z "${PYTHON_CMD}" ]]; then
            if [[ -f "${VENV_PATH}/bin/python" ]]; then
                PYTHON_CMD="${VENV_PATH}/bin/python"
            elif [[ -f "${VENV_PATH}/bin/python3" ]]; then
                PYTHON_CMD="${VENV_PATH}/bin/python3"
            elif command -v python3 &>/dev/null; then
                PYTHON_CMD="python3"
            else
                echo "ralph: no Python found."
                exit 1
            fi
        fi
        if [[ ! -f "${CORE_DIR}/ralph_metrics_viewer.py" ]]; then
            echo "ralph: error — ralph_metrics_viewer.py not found in ${CORE_DIR}"
            exit 1
        fi
        cd "${PROJECT_DIR}"
        exec "${PYTHON_CMD}" "${CORE_DIR}/ralph_metrics_viewer.py" "$@"
        ;;

    migrate)
        exec python3 "${RALPH_HOME}/init.py" --migrate
        ;;

    version|--version|-v)
        echo "ralph v1.3.0"
        ;;

    help|--help|-h|"")
        cat <<'EOF'
╔══════════════════════════════════════════════════════════════╗
║         Ralph Wiggum Loop Build System v1.3.0               ║
║         "I'm helping!"                                      ║
╚══════════════════════════════════════════════════════════════╝

  Global tool — core scripts live in ~/.ralph/core/.
  Projects carry only .ralph/config.toml and project config files.

Commands:
  ralph init        Scaffold a new project (git + beads + config + templates)
  ralph setup       Post-clone setup (beads init, dolt pull, checks)
  ralph status      Show project health dashboard
  ralph design      Session 1: Analyze ticket, plan architecture (no code)
  ralph test        Session 2: Write functional/system tests from design spec
  ralph implement   Session 3: Write code to pass existing tests + unit tests
  ralph verify      Session 4: Full validation, acceptance check, close ticket
  ralph build       Run full 4-stage pipeline for a single ticket
  ralph loop        Run build loop — foreground, continuous (all-in-one)
  ralph daemon      Run build loop — background daemon (PID-file gated)
  ralph validate    Run validation gate (tests + lint + type-check)
  ralph health      Check loop health (5-point diagnostic)
  ralph report      Generate daily/weekly operational report
  ralph metrics     View loop metrics and analytics
  ralph sync        Fetch origin and report remote sync status
  ralph migrate     Convert legacy project (scripts/ralph/) to new config
  ralph version     Show version
  ralph help        Show this help

4-Session Pipeline (ralph design / test / implement / verify):
  ralph design --ticket=<id> [--agent=pi|kimi]     # Plan architecture — no code, no tests
  ralph test --ticket=<id> [--agent=pi|kimi]        # Write functional/system tests from spec
  ralph implement --ticket=<id> [--agent=pi|kimi]  # Code to pass tests + unit tests only
  ralph verify --ticket=<id> [--agent=pi|kimi]     # Full validation + close or flag

Build options (ralph build):
  --ticket=<id>     Ticket to build through design → test → implement → verify
  --agent=kimi|pi   Specify AI agent (default: auto-detect)
  --tier=<tier>     Validation tier: smoke | targeted | integration | full
  --auto-close      Close ticket automatically after validation pass
  --max-retries=<n> Retry failed stages (default: 2)
  --no-commit       Do not auto-commit each stage (not recommended)
  --force           Skip dirty-worktree check

Loop options (ralph loop / ralph daemon):
  --ticket=<id>     Run a single ticket and exit
  --agent=kimi|pi   Specify AI agent (default: auto-detect)
  --tier=<tier>     Test tier: smoke | targeted | integration | full
  --tag=<tag>       Filter tickets by label (e.g., --tag=phase-1)
  --force           Skip dirty-worktree check

Validate options (ralph validate):
  --tier=<tier>     Test tier: smoke | targeted | integration | full

Report options (ralph report):
  --daily [date]    Daily report (default: today)
  --weekly [weeks]  Weekly report (0 = this week, 1 = last week)
  --output text|html  Output format
  --save <path>     Save to file

Quick Start:
  ralph init                    # Create a new project
  cd <your-project>
  ralph daemon                  # Start building (background)
  ralph status                  # Check progress

New System Setup:
  git clone https://github.com/samdharma/Ralph_loop.git ~/.ralph
  bash ~/.ralph/scripts/install.sh
  source ~/.zshrc               # or ~/.bashrc
  ralph version                 # Verify: ralph v1.0.1
EOF
        ;;

    *)
        echo "ralph: unknown command '${1}'"
        echo "Run 'ralph help' for usage."
        exit 1
        ;;
esac
